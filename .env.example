APP_NAME=Ideas Studio
APP_ENV=development
APP_URL=http://localhost:8000
DATABASE_URL=sqlite:///./ideas_studio.db
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

IDEAS_PER_DAY=1
MIN_GENERATED_ARTICLE_WORDS=800
WORDS_PER_READING_MINUTE=220

# ── LLM Provider ──────────────────────────────────────────────────────────
# Pour utiliser gratuitement sans limite API cloud :
#   1. installer Ollama  →  https://ollama.com
#   2. lancer :           ollama pull qwen3:14b
#   3. fallback :         ollama pull qwen3:8b
#   4. démarrer :         DEFAULT_LLM_PROVIDER=ollama
# Options : auto (try OpenRouter > Ollama > OpenAI), ollama, openai, openrouter, mock
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_SEARCH_PROVIDER=mock

# ── Ollama (free local LLM) ───────────────────────────────────────────────
# Recommandé pour béneficier de génération IA gratuite sans limite.
# qwen3:14b pour machine 16Go+, qwen3:8b pour machine 8Go+, qwen3:30b pour machine 32Go+
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
OLLAMA_FALLBACK_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=180

# ── OpenAI (payant) ───────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── OpenRouter (gratuit si modèle ":free") ────────────────────────────────
# Obtiens ta clé : https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_WRITER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_PLANNER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_FALLBACK_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

SEARXNG_URL=

BLOG_REVALIDATE_URL=
BLOG_REVALIDATE_SECRET=
